  {
    "name": "@finguard/sdk",
    "version": "0.1.0",
    "description": "TypeScript SDK for FinGuard policy checks and approvals.",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "files": ["dist", "README.md", "LICENSE"],
    "scripts": {
      "build": "tsup src/index.ts --format esm --dts --clean",
      "test": "vitest run",
      "typecheck": "tsc --noEmit"
    },
    "engines": {
      "node": ">=18"
    },
    "devDependencies": {
      "tsup": "latest",
      "typescript": "latest",
      "vitest": "latest"
    }
  }

